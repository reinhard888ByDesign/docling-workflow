# Wilson secrets — copy to ~/.openclaw/secrets.env on Wilson (never commit this file)
# secrets.env is loaded by all Wilson systemd services via EnvironmentFile=

# Hotelbär (Dispatcher Bot)
TELEGRAM_BOT_TOKEN=<dispatcher-bot-token>

# Wilson AI Assistant Bot (openclaw-gateway uses openclaw.json directly)
# TELEGRAM_BOT_TOKEN_WILSON=<wilson-bot-token>

# Lärmbär (Home Assistant Bot)
LAERENBAER_BOT_TOKEN=<laerenbaer-bot-token>

# DeepSeek API
DEEPSEEK_API_KEY=<deepseek-api-key>
